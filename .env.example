# ─── VK Bot (legacy single-group mode) ───────────────────────────
# If set, this group will be auto-migrated to the multi-tenant DB on first start
VK_TOKEN=
VK_GROUP_ID=0
OWNER_VK_ID=0

# ─── VK App (multi-tenant mode) ─────────────────────────────────
# Create app at https://dev.vk.com/ -> type "Community application"
VK_APP_ID=
VK_APP_SECRET=
VK_APP_SERVICE_KEY=
BASE_URL=https://yourdomain.com

# ─── VK Mini App ─────────────────────────────────────────────────
VK_MINIAPP_ID=
VK_MINIAPP_SECRET=

# ─── AI Provider ─────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=openai/gpt-4o-mini

# ─── GitHub (for private repos — patch notes) ───────────────────
GITHUB_TOKEN=

# ─── Telegram (cross-posting) ───────────────────────────────────
# Global fallback; per-group tokens override via dashboard settings
TELEGRAM_BOT_TOKEN=

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./vkbot.db
# For production (Docker):
# DATABASE_URL=postgresql+asyncpg://vkbot:vkbot_password@db:5432/vkbotdb

# ─── Image Search (Pexels, free, 200 req/hr) ─────────────────────
# Register at https://www.pexels.com/api/ to get a free API key
PEXELS_API_KEY=

# ─── Security ────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
JWT_SECRET=change-me-to-random-secret
API_KEY=
